# 1. Set Version
VERSION2=$VERSION 
TARGET_DIR="/var/lib/jenkins/workspace/node-online"

# 2. Re-create a clean target directory
echo "Cleaning and re-creating $TARGET_DIR..."
rm -rf "$TARGET_DIR"
mkdir -p "$TARGET_DIR"
cd "$TARGET_DIR"

# 3. Download the tarball directly into the target folder
echo "Downloading version $VERSION2..."
curl -u admin:123 -L "http://10.0.2.15:8081/repository/node-online/node-app-${VERSION2}.tar.gz" -o "package.tar.gz"

# 4. Extract the file that is now inside the folder
echo "Extracting..."
tar -xzf "package.tar.gz"

# 5. Remove the tarball after extraction to keep the folder clean
rm "package.tar.gz"

# 6. Install and Restart
echo "Installing dependencies..."
npm install --production

echo "Restarting application..."
pm2 restart node-app1 || pm2 start index.js --name node-app1
pm2 save

echo "Rollback to $VERSION2 successful!"
